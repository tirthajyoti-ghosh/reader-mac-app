<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Non-sandboxed for personal use: full access to the watched folder and
         to arbitrary files opened from anywhere. See README for the future
         sandboxed/notarized path (security-scoped bookmarks + hardened runtime). -->
    <key>com.apple.security.app-sandbox</key>
    <false/>
</dict>
</plist>
