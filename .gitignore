# macOS
.DS_Store

# Xcode project is generated by XcodeGen (`xcodegen generate`) — not committed
*.xcodeproj/

# Xcode build output / user state
# NOTE: build into build.noindex/ — the .noindex suffix keeps Spotlight from
# indexing the produced .app (otherwise dev builds show up as duplicate apps).
DerivedData/
build/
build.noindex/
*.xcuserstate
xcuserdata/
.swiftpm/

# Vendoring scratch (the resolved libs/fonts in WebResources/ ARE committed)
node_modules/
scripts/.vendor-tmp/
scripts/.iconset-tmp/
